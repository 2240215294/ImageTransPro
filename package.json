{
  "name": "imagetrans-pro",
  "version": "1.0.0",
  "description": "ImageTrans Pro - Image text overlay desktop tool",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "vite build && electron .",
    "build": "vite build",
    "dist": "vite build && electron-builder",
    "vite:dev": "vite"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.imagetrans.pro",
    "productName": "ImageTrans Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*.cjs",
      "package.json"
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052"
    }
  }
}
